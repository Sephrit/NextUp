{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Next Up",
  "version": "0.2.0",
  "identifier": "com.nextup.watchtracker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{
      "title": "Next Up",
      "width": 1180,
      "height": 780,
      "minWidth": 380,
      "minHeight": 600,
      "resizable": true,
      "fullscreen": false,
      "decorations": true
    }],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https: data:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "category": "Entertainment",
    "shortDescription": "A private shared watch tracker",
    "longDescription": "Track movies, series, sessions, ratings, collections, and your personal Moviedex.",
    "copyright": "Copyright Next Up contributors",
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
